DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_plan?schema=public"

# 可选：配置后「生成计划」前的 /plans/assistant 会调用 DeepSeek（勿把真实密钥提交到 Git）
# 必须复制本文件为同目录的 .env，或写在仓库根目录 ai-plan/.env；只编辑本示例文件不会生效。
