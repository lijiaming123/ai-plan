generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id          String      @id @default(cuid())
  userId      String
  goal        String
  deadline    DateTime
  requirement String
  type        String
  status      String      @default("active")
  stages      PlanStage[]
  createdAt   DateTime    @default(now())
}

model PlanStage {
  id        String   @id @default(cuid())
  planId    String
  name      String
  sortOrder Int
  createdAt DateTime @default(now())

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model TaskSubmission {
  id        String             @id @default(cuid())
  taskId    String
  userId    String
  content   String
  status    String             @default("in_review")
  images    SubmissionImage[]
  createdAt DateTime           @default(now())

  @@index([taskId])
  @@index([userId])
}

model SubmissionImage {
  id            String          @id @default(cuid())
  submissionId   String
  url           String
  hash          String
  createdAt     DateTime        @default(now())

  submission TaskSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model RuleConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
